# deploy/vllm 설정 — 복사해서 .env 로 쓰기 (.env 는 gitignore 됨).
#   cp deploy/vllm/.env.example deploy/vllm/.env  후 값 채우기

# --- 컨테이너 ---
CONTAINER_NAME=vllm_mblt
VLLM_PORT=8000

# --- HuggingFace ---
# mobilint/ 모델 다운로드용 토큰 (조직 계정)
HF_TOKEN=hf_YOUR_TOKEN_HERE
HF_CACHE_PATH=/home/gpuadmin/.cache/huggingface   # 모델 캐시 영구 저장(재다운 방지)

# --- 모델 (이것만 바꿔 끼우면 됨) ---
# 텍스트: mobilint/Llama-3.2-1B-Instruct / mobilint/Qwen3-2B ...
# VLM:   mobilint/Qwen3-VL-2B-Instruct / -4B- / -8B-
MODEL_NAME=mobilint/Qwen3-VL-2B-Instruct
SERVED_NAME=qwen3-vl
MAX_MODEL_LEN=4096   # Qwen3-VL-2B는 4096 (모델 config max_position_embeddings 따를 것)

# --- (참고) 런타임 배치 — 기본 command는 이걸 안 씀. batch=1 운영 기준 ---
# ⚠️ Qwen3-VL은 --model-loader-extra-config로 dev_no/max_batch_size를 넘기면 from_pretrained에서
#    TypeError로 엔진이 죽는다(실측). VLM은 config.json 레이아웃(=batch1)만 쓴다.
# ⚠️ 배치>1: MXQ가 batch로 컴파일돼 있어야 함. 현재 mobilint/Qwen3-VL-2B는 batch=1.
#    → batch 필요 시 Mobilint에 batch-compiled Qwen3-VL MXQ 요청(Llama-3.2-1B-Instruct-Batch32 참고).
# (텍스트 batch 모델에서만) docker-compose.yml command에 아래를 수동 추가:
#    - --model-loader-extra-config
#    - '{"dev_no":0}'
